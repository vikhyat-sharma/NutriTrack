DATABASE_URL=postgresql://postgres:postgres@localhost:5432/macrowise

# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-minimum-32-chars

# Google OAuth (required for /auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of allowed CORS origins (no trailing slash)
# Example: http://localhost:5173,https://app.macrowise.com
CORS_ORIGIN=http://localhost:5173

PORT=3000
