{
  "name": "macrowise",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "pnpm --filter @macrowise/server dev",
    "dev:web": "pnpm --filter @macrowise/web dev",
    "dev:mobile": "pnpm --filter @macrowise/mobile start",
    "build:server": "pnpm --filter @macrowise/server build",
    "build:web": "pnpm --filter @macrowise/web build",
    "db:migrate": "pnpm --filter @macrowise/server exec prisma migrate dev",
    "db:generate": "pnpm --filter @macrowise/server exec prisma generate",
    "db:studio": "pnpm --filter @macrowise/server exec prisma studio"
  }
}
